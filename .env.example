# ==========================================
# Watchdog — shared env for local dev
# Copy to .env and fill in. Loaded by all apps.
# ==========================================

NODE_ENV=development

# ---------- Database ----------
# Primary (writes). Matches docker-compose.yml.
DATABASE_URL=postgres://monitor_user:monitor_password@localhost:5433/monitoreo_recursos
# Read replica. Use for read-only queries.
DATABASE_READ_URL=postgres://monitor_user:monitor_password@localhost:5434/monitoreo_recursos

# ---------- Redis / BullMQ ----------
REDIS_URL=redis://localhost:6379

# ---------- API (Fastify) ----------
API_PORT=3001
API_HOST=0.0.0.0

# ---------- Web (Next.js) ----------
# URL the web app calls for the API
NEXT_PUBLIC_API_URL=http://localhost:3001

# ---------- Auth ----------
# Generate with: npx auth secret
AUTH_SECRET=

# ---------- Agent (Go) ----------
# Where the agent POSTs metrics
AGENT_API_URL=http://localhost:3001
AGENT_SAMPLE_INTERVAL=5s

# ---------- Linear sync (solo para scripts/linear-sync.ts) ----------
# Personal API key: https://linear.app/settings/api
LINEAR_API_KEY=
